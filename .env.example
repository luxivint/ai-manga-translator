# =============================================================================
# manga-translation worker — environment configuration
# Copy this file to .env and fill in the values for your deployment.
# Every value below is optional unless marked (required); defaults shown
# are what the code falls back to when a variable is unset.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required) — used by worker.py to poll the pipeline_jobs queue
# and write back chapter_assets / ChapterPage rows, and by the translator to
# log OpenAI usage events.
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# Storage backend — choose where raw/translated images are read from and
# written to. STORAGE_BACKEND=r2 (default) uses Cloudflare R2 (or any
# S3-compatible bucket); STORAGE_BACKEND=local uses plain disk, useful for
# running the pipeline fully offline / on a single machine.
# -----------------------------------------------------------------------------
STORAGE_BACKEND=r2

# Used only when STORAGE_BACKEND=local — root directory that raw/translated
# prefixes are resolved against.
LOCAL_STORAGE_ROOT=./storage

# Used only when STORAGE_BACKEND=r2
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public base URL the bucket is served from (used to build the URLs stored
# in the database for translated images).
R2_PUBLIC_BASE_URL=

# Prefixes (folders) inside the bucket/local root that raw and translated
# chapter images live under.
R2_RAW_PREFIX=raw
R2_TRANSLATED_PREFIX=translated

# Delete the raw chapter images after a successful translation, and whether
# to keep the temporary working directory used during a batch run.
R2_DELETE_RAW_AFTER_TRANSLATE=true
R2_WORKDIR=work/r2
R2_KEEP_WORKDIR=false

# -----------------------------------------------------------------------------
# Branding / SEO — fully configurable so the same code can be deployed for
# any site, in any language, without touching a single line of code.
# -----------------------------------------------------------------------------
# Used to build the alt/title text written to the database for each page.
# Placeholders available: {site_name} {language_phrase} {slug} {number} {page}
SEO_TITLE_TEMPLATE={site_name} {language_phrase} {slug} bölüm {number} sayfa {page}
SEO_SITE_NAME=TrendManga
SEO_LANGUAGE_PHRASE=Türkçe manga oku

# Used to build the uploaded image filename.
# Placeholders available: {brand} {language_slug} {series} {chapter} {page} {ext}
SEO_FILENAME_TEMPLATE={brand}-{language_slug}-{series}-{chapter}-sayfa-{page}{ext}
SEO_IMAGE_BRAND=trendmanga
SEO_FILENAME_LANGUAGE_SLUG=turkce-manga-oku

# -----------------------------------------------------------------------------
# Translation languages
# -----------------------------------------------------------------------------
SOURCE_LANG=English
TARGET_LANG=Turkish

# -----------------------------------------------------------------------------
# Pipeline engine selection
# -----------------------------------------------------------------------------
DETECTOR=RT-DETR-v4-s-int8
OCR=Qwen3-VL-Flash Grid OCR
TRANSLATOR=GPT-5.4-mini

# -----------------------------------------------------------------------------
# Text cleaning (inpainting) — pixel-level recipe:
#   YOLOv8 comic-text-segmenter -> bubble-interior Otsu -> block-aware LaMa.
# The segmenter model downloads automatically on first use. Tune only if you
# see residual text (raise dilation) or over-erasing (lower it).
# -----------------------------------------------------------------------------
# Segmenter confidence threshold (lower = catches more faint/small text).
SEG_CONF=0.25
# Mask post-processing kernels (pixels): CLOSE bridges gaps between letters/
# lines, DILATE grows the final mask so anti-aliased edges are covered too.
MASK_CLOSE=13
MASK_DILATE=13

# -----------------------------------------------------------------------------
# Scanlation/fansub ad removal — the translator (GPT) flags blocks that are a
# competing group's promo (site links, Discord invites, "read at X.com",
# "premium chapters", QR prompts, watermark site names) instead of story text.
# Your own brand (SEO_SITE_NAME) is never flagged.
# -----------------------------------------------------------------------------
# Drop whole pages that are nothing but an ad (Discord/QR/WARNING pages).
SKIP_FULL_AD_PAGES=true
# A flagged ad block is only erased if its area is at least this fraction of
# the page — so big in-page ads get removed but tiny corner watermarks are
# left alone. Raise to keep more, lower to erase smaller ads.
AD_MIN_AREA_RATIO=0.015

# Required when OCR is set to a Qwen engine (the default above) - get a key
# from https://dashscope.console.aliyun.com/. Not needed if you switch OCR
# to a non-Qwen engine.
DASHSCOPE_API_KEY=

OPENAI_API_KEY=
# Model id actually sent to the OpenAI API by the translator/quality-score/
# GPT-OCR-empty-bubble passes.
OPENAI_MODEL=gpt-5.4-mini
# Optional fixed pricing overrides (USD per 1M tokens); otherwise inferred
# from the model name.
OPENAI_INPUT_PRICE_PER_1M=
OPENAI_OUTPUT_PRICE_PER_1M=
OPENAI_CACHED_INPUT_PRICE_PER_1M=
LOG_OPENAI_USAGE=true
OPENAI_USAGE_SOURCE=manga-translation-worker
OPENAI_USAGE_OPERATION=translation
OPENAI_USAGE_DEBUG=false

USE_GPU=false

# -----------------------------------------------------------------------------
# Font / rendering
# -----------------------------------------------------------------------------
FONT_FAMILY=Arial
# Path to a .ttf/.otf file to register and use for rendering. Strongly
# recommended: headless/offscreen Qt has no real system font fallback, so
# leaving this empty produces missing-glyph boxes for non-ASCII text (e.g.
# Turkish). A font is bundled at assets/Comic Geek.ttf for convenience —
# swap in your own .ttf/.otf to change the look, or point FONT_FAMILY at an
# installed system font instead and clear this value.
FONT_FILE=assets/Comic Geek.ttf
MIN_FONT_SIZE=14
MAX_FONT_SIZE=58
UPPERCASE=true
NO_OUTLINE=false

# Optional repeating watermark/stamp overlay, applied every STAMP_EVERY_PAGES
# pages. assets/brand-stamp.png is a sample brand stamp - replace it (or
# point STAMP_PATH elsewhere) with your own, or set STAMP_ENABLED=false to
# disable it entirely.
STAMP_ENABLED=true
STAMP_PATH=assets/brand-stamp.png
STAMP_EVERY_PAGES=5
STAMP_OPACITY=1.0
STAMP_WIDTH_RATIO=0.2
STAMP_BLACK_BACKGROUND=false

# -----------------------------------------------------------------------------
# Output
# -----------------------------------------------------------------------------
OUTPUT_SUFFIX=_translated
OUTPUT_FORMAT=webp
WEBP_MAX_DIMENSION=16000
# Zip the output/ folder into output.zip after a local (non-R2) run
# finishes - convenient for grabbing/sharing a single file.
ZIP_OUTPUT=false

# -----------------------------------------------------------------------------
# Batch / worker behavior
# -----------------------------------------------------------------------------
WORKER_IDLE_SECONDS=15
# If set, the worker runs this shell command once on startup instead of
# polling the job queue (useful for one-off maintenance commands in the
# same container image).
WORKER_STARTUP_COMMAND=
BATCH_TRANSLATE_SIZE=400
BATCH_WORKERS=2
PAGE_MAX_RETRIES=3
BATCH_PIPELINE=false

# Optional: dump raw per-call token usage to a file for cost debugging
# (see "Speed & cost" in the README). QWEN_GRID_OCR_USAGE_PATH writes a
# JSON summary of every OCR call; BATCH_TRANSLATE_USAGE_PATH appends one
# JSON line per batch-translate GPT call. Leave empty to disable both.
QWEN_GRID_OCR_USAGE_PATH=
BATCH_TRANSLATE_USAGE_PATH=

# Optional: ping a web app to invalidate its cache after a chapter is
# translated. Leave empty to disable.
WEB_INTERNAL_URL=
INTERNAL_API_KEY=

# -----------------------------------------------------------------------------
# Translation quality score (optional, costs extra OpenAI calls)
# -----------------------------------------------------------------------------
TRANSLATION_QUALITY_SCORE=false
QUALITY_SCORE_SAMPLE=20

# -----------------------------------------------------------------------------
# OCR cleanup / text-detection heuristics — sensible defaults for manga;
# tune only if you see specific artifacts in your output.
# -----------------------------------------------------------------------------
DROP_NON_ENGLISH_OCR_BLOCKS=true
NON_ENGLISH_MIN_LATIN_RATIO=0.35
DROP_DENSE_BACKGROUND_TEXT=true
DENSE_TEXT_MIN_CHARS=120
DENSE_TEXT_MIN_DENSITY=0.0022
PRUNE_OCR_BLOCKS=true
DROP_EMPTY_OCR_BLOCKS=true
OCR_DUPLICATE_OVERLAP=0.92
SKIP_NOISY_OCR=true
STRIP_TRANSLATION_GARBAGE_LETTERS=true
TRANSLATION_GARBAGE_LETTERS=T L Y H I E LL
DEBUG_TRANSLATION_BLOCKS=false
RESTORE_UNTRANSLATED_REGIONS=true
EXTRA_CONTEXT=

GPT_OCR_EMPTY_BUBBLES=false
GPT_OCR_EMPTY_MAX=10
GPT_OCR_EMPTY_PAD=28

HD_STRATEGY=Resize
RESIZE_LIMIT=960

# -----------------------------------------------------------------------------
# Bubble cleaning / inpainting heuristics — defaults tuned for typical manga
# speech bubbles, override only if your source material is unusual.
# -----------------------------------------------------------------------------
CLEAN_WHITE_BUBBLES=true
BUBBLE_CLEAN_PAD=36
BUBBLE_EDGE_GUARD=10
BUBBLE_CLEAN_MIN_LUMA=185
BUBBLE_CLEAN_MAX_CHROMA=42
BUBBLE_TEXT_MAX_LUMA=238
BUBBLE_TEXT_MAX_CHROMA=110
BUBBLE_CLEAN_FILL_REGION=mask
BUBBLE_CLEAN_FILL_DELTA=8
BUBBLE_CLEAN_GHOST_DELTA=4

PROTECT_BUBBLE_OUTLINES=true
BUBBLE_OUTLINE_EDGE_MARGIN=34
BUBBLE_OUTLINE_MAX_LUMA=135
BUBBLE_OUTLINE_MAX_CHROMA=120
BUBBLE_OUTLINE_MIN_AREA=8
BUBBLE_OUTLINE_TEXT_GUARD=10
BUBBLE_OUTLINE_TEXT_OVERLAP_LIMIT=0.35
BUBBLE_OUTLINE_PROTECT_LONG_CURVES=false
BUBBLE_OUTLINE_EDGE_MIN_EXTENT=28
BUBBLE_OUTLINE_EDGE_MIN_AREA=22
BUBBLE_OUTLINE_MAX_FILL_RATIO=0.42

PROTECT_TEXT_CLEAR_PAD_X=48
PROTECT_TEXT_CLEAR_PAD_Y=24

CROP_CLEAN_DARK_MAX=125
CROP_CLEAN_WHITE_MIN=178
CROP_CLEAN_WHITE_SAT_MAX=105
CROP_CLEAN_DILATE=1
CROP_CLEAN_FEATHER=9

PANEL_SKIP_WHITE_RATIO=0.42
PANEL_SKIP_SAMPLE_PAD=28
PANEL_SKIP_MAX_STD=34

FILL_LIGHT_TEXT_REGIONS=true
LIGHT_FILL_PAD=10
LIGHT_FILL_WHITE_RATIO=0.45
LIGHT_FILL_FULL_RECT_WHITE_RATIO=0.62
LIGHT_FILL_FREE_TEXT_EXTRA_PAD=28
LIGHT_FILL_GRAY_MIN=180
LIGHT_FILL_SAT_MAX=90
LIGHT_FILL_MASK_DILATE=7

CLEAR_LIGHT_RENDER_REGIONS=true
LIGHT_RENDER_CLEAR_PAD_X=220
LIGHT_RENDER_CLEAR_PAD_Y=58
LIGHT_RENDER_CLEAR_WHITE_RATIO=0.52
LIGHT_RENDER_CLEAR_BAND_WHITE_RATIO=0.70
LIGHT_RENDER_CLEAR_GRAY_MIN=180
LIGHT_RENDER_CLEAR_SAT_MAX=100

CLEAR_LIGHT_BUBBLE_RENDER_REGIONS=false
LIGHT_BUBBLE_RENDER_CLEAR_PAD_X=42
LIGHT_BUBBLE_RENDER_CLEAR_PAD_Y=24
LIGHT_BUBBLE_RENDER_CLEAR_WHITE_RATIO=0.55
LIGHT_BUBBLE_RENDER_CLEAR_GRAY_MIN=176
LIGHT_BUBBLE_RENDER_CLEAR_SAT_MAX=110
LIGHT_BUBBLE_RENDER_EDGE_GUARD=18
LIGHT_BUBBLE_RENDER_DARK_MAX=150
LIGHT_BUBBLE_RENDER_STROKE_GRAY_MIN=205
LIGHT_BUBBLE_RENDER_STROKE_SAT_MAX=85
LIGHT_BUBBLE_RENDER_MASK_DILATE=5
LIGHT_BUBBLE_RENDER_FULL_RECT_WHITE_RATIO=1.01
LIGHT_BUBBLE_RENDER_CLAMP_TO_BUBBLE=false

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
# Override the OS cache/data directory name used for downloaded model
# weights and logs (defaults to "MangaTranslationWorker").
DATA_DIR_NAME=MangaTranslationWorker

# CLI-only override: an explicit R2/local prefix pair for scripts/local_batch.py
# when invoked manually outside of the worker queue.
R2_INPUT_PREFIX=
R2_OUTPUT_PREFIX=
